{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "display": {
    "separator": " ⟫ ",
    "key": {
      "width": 18 
    },
    "color": {
      "keys": "magenta"
    }
  },
  "modules": [
    "title",
    {
      "type": "separator",
      "string": "—"
    },
    "os",
    "host",
    {
      "type": "kernel",
      "format": "{2}"
    },
    "uptime",
    "separator",
    "packages",
    "shell",
    "separator",
    {
      "type": "display",
      "compactType": "original",
      "key": "Display"
    },
    "wm",
    "separator",
    // Тут мы всё лишнее выкинули, оставили только самое нужное
    "terminal",
    {
      "type": "terminalfont",
      "format": "{1}",
      "key": "Font" // Переименовал в просто Font для краткости
    },
    "separator",
    "cpu",
    {
      "type": "gpu",
      "format": "{2}"
    },
    "memory",
    "swap",
    "disk",
    "break",
    "colors"
  ]
}
