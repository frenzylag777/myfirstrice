{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 0,
    "height": 44,
    "modules-left": ["hyprland/workspaces", "tray"],
    "modules-center": ["clock", "pulseaudio"],
    "modules-right": ["hyprland/language","network","cpu", "memory"],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    },
    "clock": {
        "format": "{:%H:%M}",
        "tooltip-format": "{:%Y-%m-%d %H:%M:%S}"
    },
    "cpu": {
    	"interval": 3,
    	"format": " {usage}%",
    	"max-length": 20,
    	"states": {
    		"normal": 50,
    	    "warning": 70,
    	    "critical": 90
    	}
    },
    "memory": {
    	"format": " {}%",
    	"interval": 5,
    	"max-length": 20,
    	"states": {
    		"warning": 60,
    		"critical": 90
    	}
    },
    "network": {
        "format-wifi": "{icon} {essid}",
        "format-ethernet": "󰈀 {ifname}",
        "format-disconnected": "󰖪 Disconnected",
        "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"]
    },
    "tray": {
    	"spacing": 10	
    },
    "pulseaudio": {
    	"on-click": "pavucontrol",
    	"format": "󰕾 {volume}%"
    }
}
